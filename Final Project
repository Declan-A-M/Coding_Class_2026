let furby
let maul


function preload(){
furby = loadImage('images/FighterSelect.png')
maul = loadImage('images/Maul.png')
}


function setup(){
	createCanvas(windowWidth, windowHeight)
imageMode(CENTER)
background(95, 21, 5)
}


function draw(){
textSize(60)
text('Choose Your Fighter!', 600, 200)

 if(mouseIsPressed == true){
 	background(45,23,84)
 }else{
 	background(95,21,5)
 }

image(furby, windowWidth/2, windowHeight/2)

}
